# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=your_db_host_here
DB_PORT=5432
DB_NAME=cpms
DB_USER=cpms_user
DB_PASSWORD=your_password_here
DATABASE_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

# ── Server ────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_ORIGIN=https://your-domain.com

# ── OCPP ──────────────────────────────────────────────────────────────────
OCPP_PROTOCOL=ocpp1.6
OCPP_HEARTBEAT_INTERVAL=30
OCPP_WS_ENDPOINT=wss://your-domain.com/ocpp/{chargePointId}
OCPP_BASE_WS_ENDPOINT=wss://your-domain.com/ocpp

# ── Billing ───────────────────────────────────────────────────────────────
TARIFF_PER_KWH=0.33

# ── Auth ──────────────────────────────────────────────────────────────────
OCPP_OPEN_AUTH=true

# ── Charger defaults ──────────────────────────────────────────────────────
DEFAULT_CHARGER_MAX_KW=22

# ── Buffers & message retention ───────────────────────────────────────────
MSG_HISTORY_LIMIT=80
CMD_BUFFER_LIMIT=120
MSG_BUFFER_LIMIT=200
MSG_DB_RETENTION=7d
