# ── API origin (leave empty in dev — Vite proxy handles it) ──────────────
# In production set this to your deployed backend URL.
VITE_API_URL=https://your-domain.com

# ── Dev proxy target (only used by vite.config.js, not bundled) ──────────
BACKEND_URL=http://localhost:3001
DEV_PORT=5173

# ── Localisation ──────────────────────────────────────────────────────────
VITE_CURRENCY_SYMBOL=RM

# ── UI copy (optional — defaults shown) ──────────────────────────────────
VITE_STATUS_OK=All systems nominal
VITE_STATUS_RECONNECTING=Reconnecting...
